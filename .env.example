# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Stripe — create an account at https://stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key

# Stripe webhook secret — get from Stripe Dashboard > Webhooks after registering the endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Premium plan price ID (create in Stripe Dashboard > Products)
STRIPE_PREMIUM_PRICE_ID=price_your-premium-price-id

# Resend — email delivery for CTO digest (https://resend.com)
RESEND_API_KEY=re_your-resend-api-key

# Email address to receive the daily CTO feedback digest
CTO_DIGEST_EMAIL=cto@example.com
